<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0"
      alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.project4.OrderCurrentController">

    <padding>
        <Insets top="20" bottom="20" left="20" right="20"/>
    </padding>

    <!-- Title -->
    <Label text="Current Order"
           style="-fx-font-size: 24px; -fx-font-weight: bold;" />

    <!-- Pizzas in current order -->
    <Label text="Pizzas in Order"/>

    <ListView fx:id="currentOrderList"
              prefHeight="200"
              prefWidth="400"/>

    <!-- Metrics Section -->
    <VBox spacing="10" alignment="CENTER">

        <Label text="Order Summary"
               style="-fx-font-size: 16px; -fx-font-weight: bold;" />

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Number of Pizzas:"/>
            <Label fx:id="numPizzasLabel" text="0"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Sales Tax:"/>
            <Label fx:id="taxLabel" text="$0.00"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Subtotal:"/>
            <Label fx:id="subtotalLabel" text="$0.00"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Total Price:"/>
            <Label fx:id="totalLabel" text="$0.00"/>
        </HBox>

    </VBox>

    <!-- Action Buttons -->
    <HBox spacing="20" alignment="CENTER">

        <Button text="Remove Selected Pizza" fx:id="removePizzaBtn"/>
        <Button text="Place Order" fx:id="placeOrderBtn"/>

    </HBox>

</VBox>