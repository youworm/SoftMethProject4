<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0"
      alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.project4.ChicagoController">

    <padding>
        <Insets top="20" bottom="20" left="20" right="20"/>
    </padding>

    <Button text="Back" onAction="#onBackClick"/>

    <Label text="Chicago Style Pizza"
           style="-fx-font-size: 24px; -fx-font-weight: bold;" />

    <HBox spacing="10" alignment="CENTER">
        <Label text="Pizza Type:"/>
        <ComboBox fx:id="pizzaTypeBox" prefWidth="180" onAction="#createPizza"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Size:"/>
        <ComboBox fx:id="sizeBox" prefWidth="180" onAction="#createPizza"/>
    </HBox>

    <HBox spacing="15" alignment="CENTER">
        <ImageView fx:id="pizzaImage"
                   fitHeight="180"
                   fitWidth="220"
                   preserveRatio="true"/>

        <VBox spacing="10" alignment="CENTER_LEFT">
            <HBox spacing="10">
                <Label text="Crust:"/>
                <Label fx:id="crustLabel" text=""/>
            </HBox>

            <HBox spacing="10">
                <Label text="Pizza Price:"/>
                <Label fx:id="priceLabel" text="0.00"/>
            </HBox>
        </VBox>
    </HBox>

    <Label text="Customize Toppings"/>

    <HBox spacing="20" alignment="CENTER">
        <VBox spacing="5" alignment="CENTER">
            <Label text="Available Toppings"/>
            <ListView fx:id="availableToppings" prefHeight="180" prefWidth="150"/>
        </VBox>

        <VBox spacing="10" alignment="CENTER">
            <Button text="Add →" onAction="#addTopping"/>
            <Button text="← Remove" onAction="#removeTopping"/>
        </VBox>

        <VBox spacing="5" alignment="CENTER">
            <Label text="Selected Toppings"/>
            <ListView fx:id="selectedToppings" prefHeight="180" prefWidth="150"/>
        </VBox>
    </HBox>

    <Button text="Add to Order" onAction="#addToOrder"/>
</VBox>