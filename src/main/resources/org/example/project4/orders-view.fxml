<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15.0"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.project4.OrdersController">

    <padding>
        <Insets top="20" bottom="20" left="20" right="20"/>
    </padding>

    <!-- Title -->
    <Label text="Store Orders"
           style="-fx-font-size: 24px; -fx-font-weight: bold;" />

    <!-- Order selection -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Order Number:"/>
        <ComboBox fx:id="orderComboBox" onAction="#showOrderDetails"/>
    </HBox>

    <!-- Order details -->
    <TextArea fx:id="orderDetailsArea"
              prefHeight="250"
              prefWidth="400"
              editable="false"/>

    <!-- Buttons -->
    <HBox spacing="20" alignment="CENTER">
        <Button text="Cancel Order" onAction="#cancelOrder"/>
        <Button text="Export Orders" onAction="#exportOrders"/>
        <Button text="Back" onAction="#onBackClick"/>
    </HBox>

</VBox>